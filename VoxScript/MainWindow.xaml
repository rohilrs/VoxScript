<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoxScript.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:VoxScript.Views"
    Title="VoxScript">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource BrandBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar drag region. Invisible (Mica shows through) but reserves
             vertical space so page content cannot scroll under the system
             min/max/close buttons in the top-right. Height matches the standard
             caption button height (~32px). Wired via SetTitleBar in code-behind. -->
        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Background="Transparent" />

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            PaneDisplayMode="Left"
            OpenPaneLength="240"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged">

            <!-- Sidebar Header / Logo -->
            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Spacing="10" Padding="8,12">
                    <Image Width="48" Height="48"
                           VerticalAlignment="Center">
                        <Image.Source>
                            <SvgImageSource UriSource="Assets/logo-transparent.svg" />
                        </Image.Source>
                    </Image>
                    <TextBlock Text="VoxScript"
                               FontFamily="Georgia"
                               FontSize="20"
                               Foreground="{StaticResource BrandForegroundBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="Home"
                                    Icon="Home" />
                <NavigationViewItem Content="Dictionary" Tag="Dictionary"
                                    Icon="Library" />
                <NavigationViewItem Content="Expansions" Tag="Expansions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8AB;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="History" Tag="History"
                                    Icon="Clock" />
                <NavigationViewItem Content="Personalize" Tag="Personalize">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Notes" Tag="Notes">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE70B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings"
                                    Icon="Setting" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Onboarding takeover. Hidden by default; swapped in by App.xaml.cs
             on first run, swapped out again when the wizard completes. -->
        <ContentPresenter x:Name="OnboardingPresenter"
                          Grid.Row="1"
                          Visibility="Collapsed" />
    </Grid>
</Window>
