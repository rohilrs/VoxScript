<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand Colors: #7D84B2 (primary), #D9DBF1 (light variant) -->
    <Color x:Key="BrandPrimary">#FF7D84B2</Color>
    <Color x:Key="BrandPrimaryLight">#FFD9DBF1</Color>
    <Color x:Key="BrandBackground">#FFF5F0E8</Color>
    <Color x:Key="BrandForeground">#FF1A2E24</Color>
    <Color x:Key="BrandMuted">#FF8A9490</Color>
    <Color x:Key="BrandCard">#FFFAF8F5</Color>
    <Color x:Key="BrandRecording">#FFCC4444</Color>
    <Color x:Key="BrandSuccess">#FF339966</Color>

    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="BrandPrimaryLightBrush" Color="{StaticResource BrandPrimaryLight}" />
    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackground}" />
    <SolidColorBrush x:Key="BrandForegroundBrush" Color="{StaticResource BrandForeground}" />
    <SolidColorBrush x:Key="BrandMutedBrush" Color="{StaticResource BrandMuted}" />
    <SolidColorBrush x:Key="BrandCardBrush" Color="{StaticResource BrandCard}" />
    <SolidColorBrush x:Key="BrandRecordingBrush" Color="{StaticResource BrandRecording}" />
    <SolidColorBrush x:Key="BrandSuccessBrush" Color="{StaticResource BrandSuccess}" />

    <!-- Override NavigationView colors -->
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource BrandCard}" />
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource BrandBackground}" />

    <!-- Force NavigationView item text/icon to dark on light background -->
    <SolidColorBrush x:Key="NavigationViewItemForeground" Color="{StaticResource BrandForeground}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="{StaticResource BrandForeground}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundPressed" Color="{StaticResource BrandForeground}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="{StaticResource BrandPrimary}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="{StaticResource BrandPrimary}" />


</ResourceDictionary>

