<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoxScript.Shell.RecordingIndicatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- SystemBackdrop = TransparentTintBackdrop (set in code-behind) -->
    <Grid x:ConnectionId='2' x:Name="RootGrid" Background="Transparent">
        <Border x:ConnectionId='3'
            x:Name="PillBorder"
            Background="#0A0A0A"
            CornerRadius="24"
            Padding="14,6,14,6"
            BorderThickness="1"
            BorderBrush="#40FFFFFF">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Spacing="12">

                <!-- 1. Idle mic icon -->
                <FontIcon x:ConnectionId='4'
                    x:Name="IdleMicIcon"
                    Glyph="&#xE720;"
                    Foreground="#666666"
                    FontSize="14"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 2. Pulsing red dot -->
                <Ellipse x:ConnectionId='5'
                    x:Name="PulsingDot"
                    Width="10"
                    Height="10"
                    Fill="#CC4444"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 3. Spinner -->
                <ProgressRing x:ConnectionId='6'
                    x:Name="Spinner"
                    Width="18"
                    Height="18"
                    Foreground="#7D84B2"
                    IsActive="False"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 4. Pasted checkmark -->
                <FontIcon x:ConnectionId='7'
                    x:Name="PastedCheck"
                    Glyph="&#xE73E;"
                    Foreground="#339966"
                    FontSize="16"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 5. Waveform bars -->
                <StackPanel x:ConnectionId='8'
                    x:Name="WaveformPanel"
                    Orientation="Horizontal"
                    Spacing="3"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">
                    <Border x:ConnectionId='14' x:Name="Bar0" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:ConnectionId='15' x:Name="Bar1" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:ConnectionId='16' x:Name="Bar2" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:ConnectionId='17' x:Name="Bar3" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:ConnectionId='18' x:Name="Bar4" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:ConnectionId='19' x:Name="Bar5" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:ConnectionId='20' x:Name="Bar6" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                </StackPanel>

                <!-- 6. Timer -->
                <TextBlock x:ConnectionId='9'
                    x:Name="TimerText"
                    Text="0:00"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#E0E0E0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 7. Status text -->
                <TextBlock x:ConnectionId='10'
                    x:Name="StatusText"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#E0E0E0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 8. Button separator -->
                <Border x:ConnectionId='11'
                    x:Name="ButtonSeparator"
                    Width="1"
                    Height="20"
                    Background="#26FFFFFF"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 9. Finish button -->
                <Button x:ConnectionId='12'
                    x:Name="FinishButton"
                    Content="Finish"
                    CornerRadius="14"
                    Foreground="#5BBD8A"
                    Background="#40339966"
                    BorderBrush="#80339966"
                    BorderThickness="1"
                    Padding="14,4"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 10. Cancel button -->
                <Button x:ConnectionId='13'
                    x:Name="CancelButton"
                    Width="28"
                    Height="28"
                    CornerRadius="8"
                    Background="#14FFFFFF"
                    BorderThickness="0"
                    Padding="0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE711;" Foreground="#AAAAAA" FontSize="12" />
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>

