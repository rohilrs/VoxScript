<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="VoxScript.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBackgroundBrush}"
                        >

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel HorizontalAlignment="Stretch"
                    Padding="60,40" Spacing="24">

            <!-- Page Title -->
            <StackPanel Spacing="4">
                <TextBlock Text="History"
                           FontFamily="Georgia" FontSize="40"
                           Foreground="{StaticResource BrandForegroundBrush}" />
                <TextBlock Text="Your past transcriptions"
                           FontSize="14"
                           Foreground="{StaticResource BrandMutedBrush}" />
            </StackPanel>

            <!-- Search bar -->
            <Border Background="{StaticResource BrandCardBrush}"
                    CornerRadius="12" Padding="4"
                    BorderBrush="{StaticResource BrandPrimaryLightBrush}"
                    BorderThickness="1">
                <TextBox x:ConnectionId='5' x:Name="SearchBox"
                                                                                                                
                         PlaceholderText="Search transcriptions..."
                         FontSize="14"
                         BorderThickness="0" Background="Transparent"
                                                             />
            </Border>

            <!-- Grouped transcription list -->
            <StackPanel x:ConnectionId='2' x:Name="HistoryList" Spacing="24" />

            <!-- Empty state -->
            <StackPanel x:ConnectionId='3' x:Name="EmptyState" HorizontalAlignment="Center" Spacing="6"
                        Padding="0,48" Visibility="Collapsed">
                <FontIcon Glyph="&#xE81C;" FontSize="42"
                          Foreground="{StaticResource BrandMutedBrush}"
                          HorizontalAlignment="Center" Opacity="0.25" />
                <TextBlock Text="No transcriptions yet"
                           FontSize="16"
                           Foreground="{StaticResource BrandMutedBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Your dictation history will appear here"
                           FontSize="13"
                           Foreground="{StaticResource BrandMutedBrush}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>

            <!-- Load more -->
            <Button x:ConnectionId='4' x:Name="LoadMoreButton"
                    Content="Load more"
                    HorizontalAlignment="Center"
                                                
                    Background="Transparent"
                    Foreground="{StaticResource BrandPrimaryBrush}"
                    FontSize="14" FontWeight="Medium"
                    Padding="24,8"
                    Visibility="Collapsed" />

            <Border Height="20" />
        </StackPanel>
    </ScrollViewer>
</Page>

