<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VoxScript.Shell.RecordingIndicatorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="#EB1E1E1E">
        <Border
            x:Name="PillBorder"
            Background="#EB1E1E1E"
            CornerRadius="24"
            Padding="10,10,14,10"
            BorderThickness="1"
            BorderBrush="#66CC4444"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">

                <!-- 1. Idle mic icon -->
                <FontIcon
                    x:Name="IdleMicIcon"
                    Glyph="&#xE720;"
                    Foreground="#666666"
                    FontSize="14"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 2. Pulsing red dot -->
                <Ellipse
                    x:Name="PulsingDot"
                    Width="10"
                    Height="10"
                    Fill="#CC4444"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 3. Spinner -->
                <ProgressRing
                    x:Name="Spinner"
                    Width="18"
                    Height="18"
                    Foreground="#7D84B2"
                    IsActive="False"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 4. Pasted checkmark -->
                <FontIcon
                    x:Name="PastedCheck"
                    Glyph="&#xE73E;"
                    Foreground="#339966"
                    FontSize="16"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 5. Waveform bars -->
                <StackPanel
                    x:Name="WaveformPanel"
                    Orientation="Horizontal"
                    Spacing="3"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">
                    <Border x:Name="Bar0" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:Name="Bar1" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:Name="Bar2" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:Name="Bar3" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:Name="Bar4" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:Name="Bar5" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                    <Border x:Name="Bar6" Width="3" Height="4" CornerRadius="1" Background="#CC4444" />
                </StackPanel>

                <!-- 6. Timer -->
                <TextBlock
                    x:Name="TimerText"
                    Text="0:00"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#E0E0E0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 7. Status text -->
                <TextBlock
                    x:Name="StatusText"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="#E0E0E0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 8. Button separator -->
                <Border
                    x:Name="ButtonSeparator"
                    Width="1"
                    Height="20"
                    Background="#26FFFFFF"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 9. Finish button -->
                <Button
                    x:Name="FinishButton"
                    Content="Finish"
                    CornerRadius="14"
                    Foreground="#5BBD8A"
                    Background="#40339966"
                    BorderBrush="#80339966"
                    BorderThickness="1"
                    Padding="14,4"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" />

                <!-- 10. Cancel button -->
                <Button
                    x:Name="CancelButton"
                    Width="28"
                    Height="28"
                    CornerRadius="8"
                    Background="#14FFFFFF"
                    BorderThickness="0"
                    Padding="0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE711;" Foreground="#AAAAAA" FontSize="12" />
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
