<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VoxScript.Onboarding.Controls.LevelMeter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Height="12"
          CornerRadius="6"
          Background="{StaticResource BrandMutedBrush}">
        <Rectangle x:Name="FillRect"
                   HorizontalAlignment="Left"
                   RadiusX="6" RadiusY="6">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#8AAB7E" Offset="0.0" />
                    <GradientStop Color="#C9BA58" Offset="0.7" />
                    <GradientStop Color="#C37A4A" Offset="1.0" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>
