<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VoxScript.Onboarding.OnboardingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VoxScript.Onboarding.Controls">
    <Grid Padding="36,24,36,20"
          Background="{StaticResource BrandBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:StepHeader x:Name="Header" Grid.Row="0" Margin="0,0,0,20" />

        <ContentPresenter x:Name="StepHost" Grid.Row="1" />

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Grid.Column="0"
                    Content="Back" Click="BackButton_Click" />

            <TextBlock x:Name="SkipLink" Grid.Column="1"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{StaticResource BrandMutedBrush}"
                       FontSize="12"
                       Visibility="Collapsed">
                <Hyperlink x:Name="SkipHyperlink" Click="SkipHyperlink_Click">
                    <Run Text="Skip for now" />
                </Hyperlink>
            </TextBlock>

            <Button x:Name="PrimaryButton" Grid.Column="2"
                    Content="Next" Click="PrimaryButton_Click"
                    Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
