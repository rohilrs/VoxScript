<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VoxScript.Onboarding.Steps.TryItStepView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="620" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
        <TextBlock x:Name="TitleText"
                   FontFamily="Georgia" FontSize="22" FontWeight="SemiBold" />
        <TextBlock x:Name="SubtitleText"
                   FontSize="12" Foreground="{StaticResource BrandMutedBrush}"
                   TextWrapping="Wrap" />

        <TextBlock x:Name="StatusText"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,20"
                   Foreground="{StaticResource BrandMutedBrush}" />

        <Border x:Name="TranscriptBox"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{StaticResource BrandMutedBrush}"
                Background="#FFFEFB"
                Padding="14,12,14,12"
                Visibility="Collapsed">
            <TextBlock x:Name="TranscriptText"
                       FontFamily="Georgia"
                       FontSize="14"
                       TextWrapping="Wrap" />
        </Border>

        <HyperlinkButton x:Name="TryAgainLink"
                         Content="Try again"
                         HorizontalAlignment="Center"
                         Visibility="Collapsed"
                         Click="TryAgain_Click" />

        <TextBlock x:Name="EmptyHint"
                   Text="Didn't catch anything — try again."
                   FontSize="12"
                   Foreground="{StaticResource BrandMutedBrush}"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed" />
    </StackPanel>
</UserControl>
