<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VoxScript.Views.TranscribePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrandBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="1100" Padding="60,40" Spacing="32">

            <!-- Hero -->
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Don't type, just speak"
                           FontFamily="Georgia" FontSize="42" FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource BrandForegroundBrush}" />
                <TextBlock Text="Voice-to-text that turns speech into clear, polished writing"
                           FontSize="16" HorizontalAlignment="Center"
                           Foreground="{StaticResource BrandMutedBrush}" />
            </StackPanel>

            <!-- Transcript Card -->
            <Border Background="{StaticResource BrandCardBrush}"
                    CornerRadius="16" Padding="24"
                    BorderBrush="{StaticResource BrandPrimaryLightBrush}"
                    BorderThickness="1"
                    MinHeight="200">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="TRANSCRIPT"
                                   FontSize="11" FontWeight="Medium"
                                   CharacterSpacing="120"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="CopyButton" Content="Copy"
                                HorizontalAlignment="Right"
                                Click="CopyButton_Click"
                                Background="Transparent"
                                Foreground="{StaticResource BrandMutedBrush}" />
                    </Grid>

                    <!-- Transcript text -->
                    <TextBlock x:Name="TranscriptText" Grid.Row="1"
                               Text="Press the microphone to start speaking"
                               TextWrapping="Wrap" FontSize="18"
                               LineHeight="28"
                               Foreground="{StaticResource BrandMutedBrush}" />
                </Grid>
            </Border>

            <!-- Record Button -->
            <Button x:Name="RecordButton"
                    Width="80" Height="80"
                    CornerRadius="40"
                    HorizontalAlignment="Center"
                    Click="RecordButton_Click"
                    Background="{StaticResource BrandPrimaryBrush}">
                <FontIcon Glyph="&#xE720;" FontSize="32"
                          Foreground="White" />
            </Button>

            <TextBlock x:Name="RecordHint"
                       Text="Tap to start recording"
                       FontSize="13" HorizontalAlignment="Center"
                       Foreground="{StaticResource BrandMutedBrush}" />

            <!-- Stats -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock x:Name="ModelName" Text=""
                               FontSize="13"
                               Foreground="{StaticResource BrandMutedBrush}" />
                </StackPanel>
                <TextBlock x:Name="ContextModeBadge" Text=""
                           FontSize="13"
                           Foreground="{StaticResource BrandPrimaryBrush}"
                           Visibility="Collapsed" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{StaticResource BrandSuccessBrush}" />
                    <TextBlock x:Name="StatusText" Text="Ready"
                               FontSize="13"
                               Foreground="{StaticResource BrandMutedBrush}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
